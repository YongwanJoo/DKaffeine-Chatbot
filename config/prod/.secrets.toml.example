[postgres]
# PostgreSQL 민감 정보
password = "your-password"
database_url = "postgresql+psycopg://your-user:your-password@your-host:5432/your-database-name"

[bedrock]
# AWS Bedrock 전용 자격증명
access_key_id = "your-bedrock-access-key-id"
secret_access_key = "your-bedrock-secret-access-key"

[aws_s3]
# AWS S3 인증 정보 (Bedrock KB 데이터 소스용)
access_key_id = "your-aws-s3-access-key-id"
secret_access_key = "your-aws-s3-secret-access-key"

[langsmith]
# LangSmith API 키
api_key = "your-langsmith-api-key"

[openai]
# OpenAI API 키 (선택적, 현재 미사용)
api_key = "your-openai-api-key"

[kakao_object_storage]
# 카카오 클라우드 Object Storage 인증 정보
# 이 설정은 향후 사용 예정 (현재 미사용)
kakao_access_key_id = "your-kakao-access-key-id"
kakao_secret_access_key = "your-kakao-secret-access-key"

